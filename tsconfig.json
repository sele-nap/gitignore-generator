{
  "compilerOptions": {
    "declaration":      true,
    "module":           "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir":           "./dist",
    "rootDir":          "./src",
    "skipLibCheck":     true,
    "strict":           true,
    "target":           "ES2022"
  },
  "exclude": ["dist", "node_modules"],
  "include": ["src/**/*"]
}
